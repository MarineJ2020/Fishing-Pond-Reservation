# Cloudinary Configuration (for receipt uploads - 25GB free)
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset
VITE_USE_FIREBASE_EMULATOR=false

# Functions Base URL (for Cloud Functions or App Hosting)
# Leave blank if you want the app to use Firestore fallback for bookings while functions are unavailable.
VITE_FUNCTIONS_BASE_URL=http://localhost:5001/your_project/us-central1

# Firebase Admin SDK (for Cloud Functions)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n

# Resend API (for transactional emails)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=no-reply@your-domain.com

# App URL (for email links)
APP_URL=https://your-app-url.com
