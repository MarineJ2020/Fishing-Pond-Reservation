rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function userDocPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function roleFromToken() {
      return isSignedIn() && request.auth.token.role is string ? request.auth.token.role : '';
    }

    function roleFromDoc() {
      return isSignedIn() && exists(userDocPath(request.auth.uid))
        ? get(userDocPath(request.auth.uid)).data.role
        : '';
    }

    // Admin/Staff are treated as the same role in this system.
    function isAdmin() {
      return isSignedIn() && (
        roleFromToken() in ['STAFF', 'ADMIN'] ||
        roleFromDoc() in ['STAFF', 'ADMIN']
      );
    }

    // Public browsing collections.
    match /competitions/{competitionId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /ponds/{pondId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /seats/{seatId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /settings/{settingsId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // User profiles: readable by owner or admin; only admin can change roles.
    match /users/{uid} {
      allow read: if request.auth.uid == uid || isAdmin();

      allow create: if request.auth.uid == uid
        && request.resource.data.email is string
        && request.resource.data.name is string
        && request.resource.data.role == 'CLIENT';

      allow update: if (request.auth.uid == uid
          && request.resource.data.role == resource.data.role
          && request.resource.data.email == resource.data.email)
        || isAdmin();

      allow delete: if isAdmin();
    }

    // Bookings: publicly readable (client policy). Any signed-in user can create.
    // Admin manually approves every booking, so no field-level validation here.
    match /bookings/{bookingId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();

      match /payments/{paymentId} {
        allow read: if isAdmin() || request.auth.uid == get(/databases/$(database)/documents/bookings/$(bookingId)).data.userId;
        allow create, update, delete: if isAdmin();
      }
    }

    match /seatLocks/{lockId} {
      allow read: if isAdmin() || request.auth.uid == resource.data.userId;
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.userId
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.expiresAt > request.time;
      allow delete: if isAdmin() || request.auth.uid == resource.data.userId;
      allow update: if false;
    }

    match /eventResults/{resultId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
